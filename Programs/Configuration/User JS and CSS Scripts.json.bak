nt,\n\t\t\t\t\tdpi: dpi,\n\t\t\t\t};\n\t\t\t});\n\t\t}\n\t};\n\n\tconst interval = setInterval(checkQuality, 5000);\n}\n\nfunction getUpdateButtonDpiText(button, dpi) {\n\tconst data = getDataAttributeObject(button);\n\tconst buttonText = data.text;\n\n\treturn `${buttonText} (${dpi}p)`;\n}\n\nasync function init() {\n\tlet videoElement = await findVideoElementInDocument(document);\n\n\tif (videoElement == null) {\n\t\tthrow new Error('[View Video Source] Video query timed out.');\n\t}\n\n\tconst [downloadButton, updateDownloadButton] = useButton(\n\t\t'View Video Source',\n\t\t{\n\t\t\tclasses: ['ujs-view-src-btn'],\n\t\t\tdisabled: true,\n\t\t}\n\t);\n\n\tstartVideoQualityChecker(videoElement, (resolve) => {\n\t\tconst data = resolve();\n\n\t\tconst dataVideo = data.video;\n\t\tconst dataHref = data.href;\n\t\tconst dataDpi = data.dpi;\n\n\t\tupdateDownloadButton.next({\n\t\t\tupdateText: (button) => getUpdateButtonDpiText(button, dataDpi),\n\t\t\tonClickFn: () => {\n\t\t\t\treturn () => openUrl(dataHref);\n\t\t\t},\n\t\t\tdata: {\n\t\t\t\thref: dataHref,\n\t\t\t\tdpi: dataDpi,\n\t\t\t\tdisabled: false,\n\t\t\t},\n\t\t});\n\t});\n\n\tlogVvsMessage('Created download button.');\n\tconst banner = createPageBanner([downloadButton]);\n\n\tupdateDownloadButton.subscribe((updateData) => {\n\t\tconst { data, href } = updateData;\n\n\t\tif (data == null) {\n\t\t\treturn;\n\t\t}\n\t\tconst dpi = data.dpi;\n\n\t\tif (dpi != null && dpi > 0 && dpi < 720) {\n\t\t\tconst [downloadLowQualityButton, updateDownloadLowQualityButton] =\n\t\t\t\tuseButton('Download low quality', {\n\t\t\t\t\tclasses: ['.ujs-view-src-low-quality-btn', 'ujs-view-src-btn'],\n\t\t\t\t\tdisabled: true,\n\t\t\t\t});\n\n\t\t\tupdateDownloadLowQualityButton.next({\n\t\t\t\tonClickFn: () => {\n\t\t\t\t\treturn () => openUrl(dataHref);\n\t\t\t\t},\n\t\t\t\tupdateText: (button) => getUpdateButtonDpiText(button, dpi),\n\t\t\t});\n\t\t\t\n\t\t\tbanner.appendChild(downloadLowQualityButton)\n\t\t}\n\t});\n\n\tdocument.body.appendChild(banner);\n\n\tlogVvsMessage('Created banner for URL button.');\n}\n\nfunction main() {\n\tinjectFonts('Open Sans');\n\tinit();\n}\n\nmain();\n","jsDraft":"","scss":".ujs-view-src-btn {\n\tbackground-color: #B94D21 !important;\n\t\n\t&:disabled {\n\t\tcolor: #c4c7c5 !important;\n\t\tbackground-color: #727474 !important;\n\t\ttransition: background-color 100ms !important;\n\t\tcursor: not-allowed !important;\n\t}\n}\n\n.ujs-view-src-low-quality-btn {\n\tbackground-color: #1DC057 !important;\n}\n","scssDraft":"","styleImportant":false},"r:iCiClEDYcvNGNW2zVeCG5":{"css":".ujs-button {\n  display: flex;\n  justify-content: center;\n  align-items: center;\n  height: 100%;\n  padding: 10px;\n  margin: 10px;\n  font-family: \"Open Sans\";\n  font-weight: 200;\n  color: #f0f0f0;\n  text-transform: uppercase;\n  background-color: #1d1f21;\n  border: none;\n  border-radius: 5px;\n  cursor: pointer;\n}\n.ujs-button:hover {\n  color: #e8e8e8;\n  background-color: #292c2f;\n  transition: background-color 100ms;\n}\n\n.ujs-page-banner {\n  display: flex;\n  justify-content: flex-start;\n  align-items: center;\n  position: fixed;\n  bottom: 0;\n  left: 0;\n  width: 100%;\n  height: auto;\n  background-color: #121212;\n  z-index: 99999;\n  opacity: 80%;\n}\n.ujs-page-banner:hover {\n  opacity: 1;\n  transition: opacity 200ms;\n}","cssError":"","js":"function logger() {\n\tconst [logMessage, getLogMessage] = useLogger('dom-utils');\n\treturn {\n\t\tlog: logMessage,\n\t\tcreateMessage: getLogMessage,\n\t};\n}\n\n/**\n * Returns a function that logs messages with the given prefix.\n *\n * @param prefix the log message prefix\n */\nfunction useLogger(prefix) {\n\tconst getLogMessage = (message) => `[${prefix}] ${message}`;\n\twindow.logMessage = (message) => console.log(getLogMessage(message));\n\n\treturn [window.logMessage, getLogMessage];\n}\n\nfunction createLogger(prefix) {\n\tconst getLogMessage = (message) => `[${prefix}] ${message}`;\n\tconst logMessage = (message) => console.log(getLogMessage(message));\n\n\tconst loggerId = uuidv4();\n\n\tconsole.log(`Log messages using window[\"${loggerId}\"]`);\n\n\twindow.logMessage = logMessage;\n}\n\n/**\n * Retry a function call until the function returns a non-null\n * result, or the call limit is reached.\n *\n * @param retryFn the function to retry\n * @param options retryOptions\n *   - waitTime: (optional) the time to wait between retries (default: 0ms)\n *   - maxRetries: (optional) the call limit (default: 10)\n *   - timeoutMessage: (optional) a message string to log if the execution\n *\t    limit is reached, or `false` to not log any message (default: 'Retry timed out.')\n *\n * @returns the result of the function callback if resolved to\n *   a non-null value.\n */\nasync function retry(\n\tretryFn,\n\toptions = {\n\t\twaitTime: 0,\n\t\tmaxRetries: 10,\n\t\techo: false,\n\t\ttimeoutMessage: 'Retry timed out.',\n\t}\n) {\n\tconst { waitTime, maxRetries, timeoutMessage, echo } = options;\n\n\tlet retryFnResult = await retryFn();\n\tlet retries = 0;\n\n\twhile (retryFnResult == null && retries <= maxRetries) {\n\t\tawait wait(waitTime);\n\n\t\tconst echoRetrying = echo != null && echo;\n\n\t\tif (echoRetrying) {\n\t\t\tlogMessage(`Retrying function...\\t\\t(${retries}/${maxRetries})`);\n\t\t}\n\n\t\tretryFnResult = await retryFn();\n\t\tretries++;\n\t}\n\n\tif (retries === maxRetries) {\n\t\tthrow new Error(getLogMessage(timeoutMessage));\n\t}\n\n\treturn retryFnResult;\n}\n\n/**\n * Wait a specified time (ms).\n *\n * @param time the time to wait (ms)\n *\n * @returns a new Promise that resolves to `null`\n *   after the specified wait time.\n */\nasync function wait(time) {\n\treturn new Promise((resolve) => setTimeout(() => resolve(null), time));\n}\n\n/**\n * Throws an error when the given argument value of a function\n * is not provided or undefined.\n *\n * @param fnName the name of the function\n * @param argName the name of the argument\n * @param argValue the value of the argument\n */\nfunction assertArgProvided(fnName, argName, argValue, createMessageFn) {\n\tif (argValue === undefined) {\n\t\tthrow new Error(\n\t\t\tcreateMessageFn(`Argument is required: ${argName} (${fnName})`)\n\t\t);\n\t}\n}\n\n/**\n * Create a button of the specified type.\n *\n *  @param type the type of button, either a vanilla button\n *    or an anchor with the `button` role attribute\n *  @param options options to populate the button attributes:\n *\t\t- `text`: the button text\n *    - `onClickFn`: a callback that provides the button to the\n *        consumer and returns a new callback for the button click\n *    - `disabled`: (optional) whether the button starts off disabled\n *\t\t- `href`: (optional) the target url of a link button\n *    - `classes`: (optional) list of additional css classes to apply\n */\nfunction useButton(text, { onClickFn, classes, disabled, data = {} }) {\n\tconst button = document.createElement('button');\n\tconst buttonCustomDataAttr = document.createAttribute('data');\n\n\t// set the initial button properties\n\tbutton.setAttributeNode(buttonCustomDataAttr);\n\tbutton.setAttribute('data', JSON.stringify({ text, ...data }));\n\tbutton.id = convertToCamelCase(text);\n\tbutton.classList.add(...(classes ?? []), 'ujs-button');\n\tbutton.innerText = text;\n\tbutton.disabled = disabled ?? false;\n\n\tconst clickListener =\n\t\tonClickFn == null ? () => console.log('Nothing to do.') : onClickFn(button);\n\tbutton.addEventListener('click', clickListener);\n\n\t/**\n\t * Create the update event emitter used by the consumer\n\t * to update the button data.\n\t */\n\tconst buttonUpdateEventEmitter$ = new rxjs.Subject();\n\n\tbuttonUpdateEventEmitter$.subscribe((updateData) => {\n\t\tconst { data, updateText, onClickFn, disabled } = updateData;\n\n\t\tbutton.disabled = disabled ?? false;\n\n\t\tif (updateText != null) {\n\t\t\tconst text = updateText(button);\n\t\t\tbutton.innerText = text;\n\t\t\tlogMessage(`Updated button text: ${text}`);\n\t\t}\n\n\t\tif (onClickFn != null) {\n\t\t\tconst onClick = onClickFn(button);\n\t\t\tbutton.addEventListener('click', onClickFn(button));\n\t\t\tlogMessage(`Updated button click listener: ${onClick}`);\n\t\t}\n\n\t\tconst currentData = getDataAttributeObject(button);\n\t\tconst updatedData = { ...currentData, ...data };\n\t\tlogMessage(`Current button data: ${currentData}`);\n\t\tlogMessage(`Updated button data: ${updatedData}`);\n\n\t\tsetDataAttributeObject(button, updatedData);\n\t});\n\n\treturn [button, buttonUpdateEventEmitter$];\n}\n\n/**\n * Parses the custom `data` attribute value of an element to\n * a plain object. If the value is undefined, returns an\n * empty object\n *\n * @param element the element with the `data` attribute\n */\nfunction getDataAttributeObject(element) {\n\tconst val = element.getAttribute('data');\n\n\tif (val == null) {\n\t\treturn {};\n\t}\n\n\treturn JSON.parse(val);\n}\n\n/**\n * Sets the stringified `data` attribute value of\n * an element.\n */\nfunction setDataAttributeObject(element, data) {\n\telement.setAttribute('data', JSON.stringify(data));\n}\n\n/**\n * Converts a space-separated string to a camel-case string.\n *\n * @returns the string as a camel-case.\n */\nfunction convertToCamelCase(text) {\n\tconst [firstWord, ...restWords] = text.split(' ');\n\tconst firstWordLetter = firstWord.charAt(0).toLowerCase();\n\tconst restOfFirstWord = firstWord.slice(1);\n\tconst restOfWords = restWords.join('');\n\n\treturn [firstWordLetter, restOfFirstWord, restOfWords].join('');\n}\n\n/**\n * Add the properties of a CSS styles object to an element.\n *\n * @param element the element to apply the styles to\n * @param styles an object containing CSS property keys\n *   to their values\n *\n * @returns the element with the styles applied\n */\nfunction addStyles(element, styles) {\n\tconst existingStyles = element.style ?? {};\n\n\treturn Object.assign(element.style, { ...styles, ...existingStyles });\n}\n\n/**\n * Create a banner at the bottom of the page containing the\n *  list of\tprovided elements.\n *\n * @param elements the elements to add to the banner\n */\nfunction createPageBanner(elements) {\n\tconst banner = document.createElement('div');\n\n\tbanner.classList.add('ujs-page-banner');\n\n\telements.forEach((element) => banner.appendChild(element));\n\n\treturn banner;\n}\n\n/**\n * Open the provided URL in a new tab.\n *\n * Typically used when `window.open` is not available in the\n * window context.\n *\n * @param url the URL to open in a new tab\n */\nfunction openUrl(url) {\n\tconst form = document.createElement('form');\n\n\tform.action = url.split('?')[0]; // set the form action to the base URL\n\tform.method = 'GET';\n\tform.target = '_blank'; // open request in a new tab\n\n\tconst queryParams = new URLSearchParams(url.split('?')[1]);\n\n\t/** use hidden input fields that set the URL query parameters\n\t * on submission.\n\t */\n\tqueryParams.forEach((value, key) => {\n\t\tconst input = document.createElement('input');\n\n\t\tinput.type = 'hidden';\n\t\tinput.name = key;\n\t\tinput.value = value;\n\n\t\tform.appendChild(input);\n\t\tform.submit();\n\t});\n\n\tdocument.body.appendChild(form);\n\n\t// submit the form request to open the new tab\n\tform.submit();\n\n\tdocument.body.removeChild(form);\n}\n\n/**\n * Inject Google font families into the page HTML.\n *\n * @param fontFamilies the list of Google fonts families\n * to inject into the page.\n */\nfunction injectFonts(...fontFamilies) {\n\tWebFont.load({\n\t\tgoogle: {\n\t\t\tfamilies: fontFamilies,\n\t\t},\n\t});\n}\n\nfunction init() {\n\tcreateLogger();\n\t// Inject the fonts referenced by the `dom-utils` stylesheet\n\twindow.injectFonts('Open Sans');\n}\n","jsDraft":"","scss":"$btn-bg-color: #1d1f21;\n$btn-text-color: #f0f0f0;\n\n.ujs-button {\n\tdisplay: flex;\n\tjustify-content: center;\n\talign-items: center;\n\theight: 100%;\n\tpadding: 10px;\n\tmargin: 10px;\n\tfont-family: 'Open Sans';\n\tfont-weight: 200;\n\tcolor: $btn-text-color;\n\ttext-transform: uppercase;\n\tbackground-color: $btn-bg-color;\n\tborder: none;\n\tborder-radius: 5px;\n\tcursor: pointer;\n\n\t&:hover {\n\t\tcolor: darken($btn-text-color, 3%);\n\t\tbackground-color: lighten($btn-bg-color, 5%);\n\t\ttransition: background-color 100ms;\n\t}\n}\n\n.ujs-page-banner {\n\tdisplay: flex;\n\tjustify-content: flex-start;\n\talign-items: center;\n\tposition: fixed;\n\tbottom: 0;\n\tleft: 0;\n\twidth: 100%;\n\theight: auto;\n\tbackground-color: #121212;\n\tz-index: 99999;\n\topacity: 80%;\n\t\n\t&:hover {\n\t\topacity: 1;\n\t\ttransition: opacity 200ms;\n\t}\n}\n","scssDraft":"","styleImportant":false},"r:lpVrOX1ARNxgbVCzxnczs":{"css":"","cssError":"","js":"function removePrivateVideos() {\n\tconst videoList = document.querySelector(\n\t\t'#list_videos_common_videos_list_items'\n\t);\n\tconst videos = videoList.querySelectorAll('.item.private');\n\n\tfor (const video of videos) {\n\t\tconsole.log(videoList);\n\t\tconsole.log(video);\n\t\tvideoList.removeChild(video);\n\t}\n}\n\nconst pageLinks = document.querySelectorAll('li.page');\n\nfor (const page of pageLinks) {\n\tpage.addEventListener('click', async () => {\n\t\tawait wait(1000)\n\t\tremovePrivateVideos()\n\t});\n}\n","jsDraft":"","scss":"","scssDraft":"","styleImportant":false},"r:mmUE_2MTpy6rjn2e8gJAM":{"css":".paste-button:hover {\n  cursor: pointer;\n}","cssError":"","js":"async function main() {\n\tconst searchToolbar = await retry(\n\t\t() => document.querySelector(`div[role=\"list\"]`),\n\t\t{\n\t\t\twaitTime: 200,\n\t\t\tmaxRetries: 10,\n\t\t\ttimeoutMessage: \"Couldn't resolve search toolbar.\",\n\t\t}\n\t);\n\n\tconsole.log(searchToolbar);\n\n\tif (searchToolbar == null) {\n\t\tthrow new Error('Search toolbar not found.');\n\t}\n\n\tconst pasteButton = searchToolbar\n\t\t.querySelector(`[role=\"listitem\"]`)\n\t\t.cloneNode(true);\n\tpasteButton.classList.add('paste-button');\n\n\tconsole.log(pasteButton);\n\n\tconst textElement = pasteButton.querySelector(`div[selected]`);\n\ttextElement.removeAttribute('selected');\n\ttextElement.innerText = \"Paste + add 'dildo'\";\n\n\tpasteButton.addEventListener('click', async () => {\n\t\tlet pasteText = await navigator.clipboard.readText();\n\t\tconsole.log('Clipboard text:', pasteText);\n\t\t/**\n\t\t * If no text in clipboard, copy the search term\n\t\t */\n\t\tif (pasteText == null) {\n\t\t\tconst searchBox = document.querySelector(`textarea[aria-label=\"Search\"]`);\n\t\t\tconsole.log('Search box text:', pasteText);\n\t\t\tpasteText = searchBox.value;\n\t\t\tconsole.log('Search box paste text:', pasteText);\n\t\t}\n\n\t\tsearchBox.value = `${pasteText} dildo`;\n\t\tsearchBox.dispatchEvent(new InputEvent(`${pasteText} dildo`));\n\t});\n\n\tsearchToolbar.appendChild(pasteButton);\n}\n\nmain();\n","jsDraft":"","scss":".paste-button {\n\t&:hover{\n\t\tcursor: pointer;\n\t}\n}","scssDraft":"","styleImportant":false},"rules":[{"created":1720443283297,"flags":["atStartJS"],"id":"r:YzILG5rDAQ1S4B_ssbLoL","libs":["r:iCiClEDYcvNGNW2zVeCG5","m:88fbf4517087253b61c2071ef8868d4e"],"name":"view-video-source","updated":1725977623656,"urls":"https://spankbang.com/*, https://www.camwhores.us.com/videos/*, https://www.camwhores.film/videos/*, https://camwh.com/videos/*, https://www.camwhorescloud.com/videos/*, https://www.camhub.cc/videos/*, https://hclips.com/videos/*, https://www.camwhoreshd.com/*, https://www.cambro.io/*, https://xgirls.webcam/videos/*, https://www.cambro.io/*, https://noodlemagazine.com/watch/*, https://pornzog.com/*, https://camwhores.video/*, https://camwhores.biz/*, https://recordbate.com/*, https://www.cambabe.video/*, https://www.eporner.com/*, https://www.livecamrips.com/*, https://www.xtits.xxx/*, https://xhand.net/*, https://www.webpussi.com/*, https://www.camwhores.porn/*, https://www.camporn.tube/*, https://www.camwhoresbay.com/videos/*, https://www.cambro.tv/*/**, https://www.camwhoreshd.com/*, https://www.pussyspace.com/*, https:/