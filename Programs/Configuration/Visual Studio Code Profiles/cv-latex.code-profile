{"name":"cv-latex","settings":"{\"settings\":\"{\\n  \\\"[latex]\\\": {\\n    \\\"editor.defaultFormatter\\\": \\\"James-Yu.latex-workshop\\\",\\n    \\\"editor.formatOnPaste\\\": true,\\n    \\\"editor.formatOnSave\\\": true\\n  },\\n  \\\"editor.codeActionsOnSave\\\": {\\n    \\\"source.fixAll.eslint\\\": \\\"explicit\\\"\\n  },\\n  \\\"editor.defaultFormatter\\\": \\\"esbenp.prettier-vscode\\\",\\n  \\\"editor.foldingMaximumRegions\\\": 65000,\\n  \\\"editor.fontLigatures\\\": true,\\n  \\\"editor.formatOnPaste\\\": true,\\n  \\\"editor.formatOnSave\\\": true,\\n  \\\"editor.glyphMargin\\\": false,\\n  \\\"editor.inlineSuggest.enabled\\\": true,\\n  \\\"editor.linkedEditing\\\": true,\\n  \\\"editor.minimap.autohide\\\": true,\\n  \\\"editor.minimap.enabled\\\": false,\\n  \\\"editor.minimap.maxColumn\\\": 150,\\n  \\\"editor.minimap.renderCharacters\\\": false,\\n  \\\"editor.minimap.scale\\\": 1,\\n  \\\"editor.minimap.showSlider\\\": \\\"mouseover\\\",\\n  \\\"editor.renderWhitespace\\\": \\\"none\\\",\\n  \\\"errorLens.gutterIconSet\\\": \\\"letter\\\",\\n  \\\"explorer.confirmDragAndDrop\\\": false,\\n  \\\"explorer.decorations.badges\\\": false,\\n  \\\"explorer.decorations.colors\\\": false,\\n  \\\"files.autoSave\\\": \\\"afterDelay\\\",\\n  \\\"files.eol\\\": \\\"\\\\n\\\",\\n  \\\"files.trimTrailingWhitespace\\\": true,\\n  \\\"git.confirmSync\\\": false,\\n  \\\"git.enableSmartCommit\\\": true,\\n  \\\"gitProjectManager.baseProjectsFolders\\\": [\\\"%USERPROFILE%/Desktop/Code\\\"],\\n  \\\"gitProjectManager.openInNewWindow\\\": true,\\n  \\\"github.copilot.enable\\\": {\\n    \\\"*\\\": true\\n  },\\n  \\\"markdown.validate.enabled\\\": true,\\n  \\\"sortJSON.contextMenu\\\": {\\n    \\\"sortJSONAlphaNum\\\": false,\\n    \\\"sortJSONAlphaNumReverse\\\": false,\\n    \\\"sortJSONKeyLength\\\": false,\\n    \\\"sortJSONKeyLengthReverse\\\": false,\\n    \\\"sortJSONReverse\\\": false,\\n    \\\"sortJSONType\\\": false,\\n    \\\"sortJSONTypeReverse\\\": false,\\n    \\\"sortJSONValues\\\": false,\\n    \\\"sortJSONValuesReverse\\\": false\\n  },\\n  \\\"terminal.integrated.defaultProfile.windows\\\": \\\"Git Bash\\\",\\n  \\\"terminal.integrated.enableMultiLinePasteWarning\\\": \\\"never\\\",\\n  \\\"terminal.integrated.gpuAcceleration\\\": \\\"on\\\",\\n  \\\"terminal.integrated.lineHeight\\\": 1.2,\\n  \\\"terminal.integrated.profiles.windows\\\": {\\n    \\\"Git Bash\\\": {\\n      \\\"path\\\": \\\"C:\\\\\\\\Program Files\\\\\\\\Git\\\\\\\\bin\\\\\\\\bash.exe\\\",\\n      \\\"source\\\": \\\"Git Bash\\\"\\n    },\\n    \\\"WSL\\\": {\\n      \\\"icon\\\": \\\"terminal-ubuntu\\\",\\n      \\\"path\\\": \\\"C:\\\\\\\\WINDOWS\\\\\\\\System32\\\\\\\\wsl.exe\\\",\\n      \\\"source\\\": \\\"Windows Subsystem for Linux\\\"\\n    }\\n  },\\n  \\\"workbench.editor.closeOnFileDelete\\\": true,\\n  \\\"workbench.startupEditor\\\": \\\"none\\\",\\n  \\\"workbench.tree.indent\\\": 10,\\n  \\\"workbench.iconTheme\\\": \\\"material-icon-theme\\\",\\n  \\\"files.associations\\\": {\\n    \\\"*.sty\\\": \\\"latex-expl3\\\"\\n  }\\n}\"}","keybindings":"{\"keybindings\":\"// Place your key bindings in this file to override the defaults\\n[\\n  {\\n    \\\"command\\\": \\\"revealFileInOS\\\",\\n    \\\"key\\\": \\\"ctrl+shift+z\\\"\\n  },\\n  {\\n    \\\"command\\\": \\\"editor.action.blockComment\\\",\\n    \\\"key\\\": \\\"ctrl+shift+/\\\",\\n    \\\"when\\\": \\\"editorTextFocus && !editorReadonly\\\"\\n  },\\n  {\\n    \\\"command\\\": \\\"editor.action.copyLinesDownAction\\\",\\n    \\\"key\\\": \\\"ctrl+shift+down\\\",\\n    \\\"when\\\": \\\"editorTextFocus && !editorReadonly\\\"\\n  },\\n  {\\n    \\\"command\\\": \\\"-editor.action.copyLinesDownAction\\\",\\n    \\\"key\\\": \\\"shift+alt+down\\\",\\n    \\\"when\\\": \\\"editorTextFocus && !editorReadonly\\\"\\n  },\\n  {\\n    \\\"command\\\": \\\"-workbench.action.quickOpenNavigateNextInFilePicker\\\",\\n    \\\"key\\\": \\\"ctrl+p\\\",\\n    \\\"when\\\": \\\"inFile