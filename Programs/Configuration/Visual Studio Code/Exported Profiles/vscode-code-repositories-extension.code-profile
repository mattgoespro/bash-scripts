{"name":"vscode-code-repositories-extension","settings":"{\"settings\":\"{\\r\\n  \\\"editor.defaultFormatter\\\": \\\"esbenp.prettier-vscode\\\",\\r\\n  \\\"editor.foldingMaximumRegions\\\": 65000,\\r\\n  \\\"editor.formatOnPaste\\\": true,\\r\\n  \\\"editor.formatOnSave\\\": true,\\r\\n  \\\"editor.inlineSuggest.enabled\\\": true,\\r\\n  \\\"editor.linkedEditing\\\": true,\\r\\n  \\\"editor.minimap.autohide\\\": true,\\r\\n  \\\"editor.minimap.maxColumn\\\": 150,\\r\\n  \\\"editor.minimap.renderCharacters\\\": false,\\r\\n  \\\"editor.minimap.scale\\\": 1,\\r\\n  \\\"editor.minimap.showSlider\\\": \\\"mouseover\\\",\\r\\n  \\\"code-repositories.local-search-directory\\\": \\\"${env:USERPROFILE}\\\\\\\\Desktop\\\\\\\\Code\\\",\\r\\n  \\\"errorLens.gutterIconSet\\\": \\\"letter\\\",\\r\\n  \\\"files.associations\\\": {\\r\\n    \\\".eslintignore\\\": \\\"ignore\\\"\\r\\n  },\\r\\n  \\\"files.eol\\\": \\\"\\\\n\\\",\\r\\n  \\\"files.trimTrailingWhitespace\\\": true,\\r\\n  \\\"git.confirmSync\\\": false,\\r\\n  \\\"gitProjectManager.baseProjectsFolders\\\": [\\\"%USERPROFILE%\\\\\\\\Desktop\\\"],\\r\\n  \\\"gitProjectManager.openInNewWindow\\\": true,\\r\\n  \\\"github.copilot.enable\\\": {\\r\\n    \\\"*\\\": true\\r\\n  },\\r\\n  \\\"npm-intellisense.recursivePackageJsonLookup\\\": false,\\r\\n  \\\"sortJSON.contextMenu\\\": {\\r\\n    \\\"sortJSONAlphaNum\\\": false,\\r\\n    \\\"sortJSONAlphaNumReverse\\\": false,\\r\\n    \\\"sortJSONKeyLength\\\": false,\\r\\n    \\\"sortJSONKeyLengthReverse\\\": false,\\r\\n    \\\"sortJSONReverse\\\": false,\\r\\n    \\\"sortJSONType\\\": false,\\r\\n    \\\"sortJSONTypeReverse\\\": false,\\r\\n    \\\"sortJSONValues\\\": false,\\r\\n    \\\"sortJSONValuesReverse\\\": false\\r\\n  },\\r\\n  \\\"terminal.integrated.defaultProfile.windows\\\": \\\"Git Bash\\\",\\r\\n  \\\"terminal.integrated.enableMultiLinePasteWarning\\\": false,\\r\\n  \\\"terminal.integrated.gpuAcceleration\\\": \\\"on\\\",\\r\\n  \\\"terminal.integrated.lineHeight\\\": 1.2,\\r\\n  \\\"terminal.integrated.profiles.windows\\\": {\\r\\n    \\\"Git Bash\\\": {\\r\\n      \\\"path\\\": \\\"C:\\\\\\\\Program Files\\\\\\\\Git\\\\\\\\bin\\\\\\\\bash.exe\\\",\\r\\n      \\\"source\\\": \\\"Git Bash\\\"\\r\\n    },\\r\\n    \\\"WSL\\\": {\\r\\n      \\\"icon\\\": \\\"terminal-ubuntu\\\",\\r\\n      \\\"path\\\": \\\"C:\\\\\\\\WINDOWS\\\\\\\\System32\\\\\\\\wsl.exe\\\",\\r\\n      \\\"source\\\": \\\"Windows Subsystem for Linux\\\"\\r\\n    }\\r\\n  },\\r\\n  \\\"workbench.editor.closeOnFileDelete\\\": true,\\r\\n  \\\"workbench.startupEditor\\\": \\\"none\\\",\\r\\n  \\\"workbench.tree.indent\\\": 10,\\r\\n  \\\"workbench.iconTheme\\\": \\\"material-icon-theme\\\",\\r\\n  \\\"git.openRepositoryInParentFolders\\\": \\\"never\\\",\\r\\n  \\\"npm-outdated.majorUpdateProtection\\\": false,\\r\\n  \\\"debug.onTaskErrors\\\": \\\"showErrors\\\"\\r\\n}\"}","keybindings":"{\"keybindings\":\"[\\n  {\\n    \\\"args\\\": {\\n      \\\"snippet\\\": \\\"console.log(${TM_SELECTED_TEXT}$1)$2;\\\"\\n    },\\n    \\\"command\\\": \\\"editor.action.insertSnippet\\\",\\n    \\\"key\\\": \\\"ctrl+shift+l\\\",\\n    \\\"when\\\": \\\"editorTextFocus\\\"\\n  },\\n  {\\n    \\\"command\\\": \\\"revealFileInOS\\\",\\n    \\\"key\\\": \\\"ctrl+shift+z\\\"\\n  },\\n  {\\n    \\\"args\\\": {\\n      \\\"snippet\\\": \\\"<$1>${TM_SELECTED_TEXT}</$1>\\\"\\n    },\\n    \\\"command\\\": \\\"editor.action.insertSnippet\\\",\\n    \\\"key\\\": \\\"ctrl+shift+k\\\",\\n    \\\"when\\\": \\\"editorTextFocus\\\"\\n  },\\n  {\\n    \\\"command\\\": \\\"editor.action.blockComment\\\",\\n    \\\"key\\\": \\\"ctrl+shift+/\\\",\\n    \\\"when\\\": \\\"editorTextFocus && !editorReadonly\\\"\\n  },\\n  {\\n    \\\"command\\\": \\\"editor.action.copyLinesDownAction\\\",\\n    \\\"key\\\": \\\"ctrl+shift+down\\\",\\n    \\\"when\\\": \\\"editorTextFocus && !editorReadonly\\\"\\n  },\\n  {\\n    \\\"command\\\": \\\"-editor.action.copyLinesDownAction\\\",\\n    \\\"key\\\"